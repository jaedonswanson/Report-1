med_age_p <- interaction_anova["Medication:Age", "Pr(>F)"]
cat("Medication × Age interaction p-value:", round(med_age_p, 4), "\n")
cat("Interpretation:", ifelse(med_age_p > 0.05,
"Slopes are homogeneous (assumption met). Safe to proceed with ANCOVA.",
"Slopes are NOT homogeneous (assumption violated). Consider including the interaction term in your model."), "\n")
print(interaction_anova)

# Loading packages
library(tidyverse)
library(car)
library(emmeans)
#### Two-Way ANOVA with sex as covariate ####
# mean and sd for bp
bp %>%
group_by(Sex, Medication) %>%
Summarise(mean = mean(BP),
sd = sd(BP))
#### Two-Way ANOVA with sex as covariate ####
# mean and sd for bp
bp %>%
group_by(Sex, Medication) %>%
summarise(mean = mean(BP),
sd = sd(BP))
# Boxplots to visualize the difference
boxplot(BP ~ Sex:Medication,
data = bp,
main = "Blood Pressure Distribution by Group",
xlab = "Group",
ylab = "Blood Pressure",
col = "firebrick")
rm(list = lm())
rm(list = lm())
# Fitting a two-way ANOVA model
sex_model <- aov(BP ~ Sex * Medication,
data = bp)
summary(sex_model)
#### Two-Way ANOVA with sex as covariate ####
# Testing Assumptions
## Independence, yes
## Normality
resid(sex_model$residuals)
#### Two-Way ANOVA with sex as covariate ####
# Testing Assumptions
## Independence, yes
## Normality
resid(sex_model$residuals)
View(sex_model)
# Testing Assumptions
## Independence, yes
## Normality
plot(residuals(sex_model))
abline(0,0)
## Looks appx normal
## Equal variance using levene's test
leveneTest(BP ~ Sex * Medication, data = bp)
# Analyzing Treatment Differences
TurkeyHSD(sex_model, conf.level = ,95)

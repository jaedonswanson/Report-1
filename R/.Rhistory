library(tidyverse)
# initial import of data to R
data <- read_csv("data.csv")
view(data)
ggplot(data) +
geom_point(aes(x = Age, y = BP),
color = Sex)
ggplot(data) +
geom_point(aes(x = Age, y = BP),
color = Sex))
ggplot(data) +
geom_point(aes(x = Age, y = BP,
color = Sex))
ggplot(data) +
geom_point(aes(x = Age, y = BP,
shape = Treatment, color = Sex))
# changing the treatment column so R sees it as a categorical variable
data$Treatment <- as.factor(data$Treatment)
ggplot(data) +
geom_point(aes(x = Age, y = BP,
shape = Treatment, color = Sex))
ggplot(data, aes(x = Sex, y = BP)) +
geom_violin()
# Visualizing the differences in BP in regards to sex regardless of treatment type
ggplot(data, aes(x = Sex, y = BP)) +
geom_violin(trim = FALSE)
# Visualizing the differences in BP in regards to medication regardless of sex
ggplot(data, aes(x = Treatment, y = BP)) +
geom_violin(trim = FALSE)
# Visualizing the differences in BP in regards to sex regardless of treatment type
ggplot(data, aes(x = Treatment, y = BP, fill = Sex)) +
geom_violin(trim = FALSE)
# Adding the data points
ggplot(data, aes(x = Treatment, y = BP, fill = Sex)) +
geom_violin(trim = FALSE) +
geom_dotplot(binaxis = 'y', stackdir = 'center',
position = position_dodge(1))
# sort the data according the the value of BP
dataSorted <- data[ order(data$BP), ]
View(dataSorted)
rm(dataSorted)
##### Part 2
moleRat <- read.csv(url("http://www.zoology.ubc.ca/~schluter/WhitlockSchluter/wp-content/data/chapter18/chap18e4MoleRatLayabouts.csv"))
# sort the data according the the value of the ln of body mass
moleRatSorted <- moleRat[ order(moleRat$lnMass), ]
# scatter plot of the data
plot(lnEnergy ~ lnMass, data = moleRat, type = "n", las = 1, bty = "l")
points(lnEnergy ~ lnMass, data = subset(moleRatSorted, caste == "worker"),
pch = 1, col = "firebrick")
points(lnEnergy ~ lnMass, data = subset(moleRatSorted, caste == "lazy"),
pch = 16, col = "firebrick")
# fit models to the data beginning wiht the model lacking an interaction term
moleRatNoInteractModel <- lm(lnEnergy ~ lnMass + caste, data = moleRatSorted)
moleRatSorted$predictedNoInteract <- predict(moleRatNoInteractModel)
# Fit the full model which includes and interaction term
moleRatFullModel <- lm(lnEnergy ~ lnMass * caste, data = moleRatSorted)
moleRatSorted$predictedInteract <- predict(moleRatFullModel)
# Visualize the model fits
lines(predictedNoInteract ~ lnMass, data = subset(moleRatSorted,
caste == "worker"), lwd = 1.5)
lines(predictedNoInteract ~ lnMass, data = subset(moleRatSorted,
caste == "lazy"), lwd = 1.5)
# scatter plot of the data
ggplot(data, aes(x = Treatment, y = BP))+
geom_jitter()
# scatter plot of the data
ggplot(data, aes(x = Medication, y = BP))+
geom_jitter()
# scatter plot of the data
ggplot(data, aes(x = Medication, y = BP))+
geom_jitter(aes(color = Sex, shape = Treatment))
plot(lnEnergy ~ lnMass, data = moleRat, type = "n", las = 1, bty = "l")
points(lnEnergy ~ lnMass, data = subset(moleRatSorted, caste == "worker"),
pch = 1, col = "firebrick")
points(lnEnergy ~ lnMass, data = subset(moleRatSorted, caste == "lazy"),
pch = 16, col = "firebrick")
# Adding the data points
ggplot(data, aes(x = Treatment, y = BP, fill = Sex)) +
geom_violin(trim = FALSE) +
geom_dotplot(binaxis = 'y', stackdir = 'center',
position = position_dodge(1))
# fit models to the data beginning wiht the model lacking an interaction term
data_No_Interact_Model <- lm(BP ~ Treatment + Sex, data = data)
View(data_No_Interact_Model)
data$predictedNoInteract <- predict(data_No_Interact_Model)
# Fit the full model which includes and interaction term
data_full_model <- lm(BP ~ Treatment * Sex, data = data)
data$predictedInteract <- predict(data_full_model)
# Visualize the model fits
lines(data_No_Interact_Model ~ BP, data = subset(data,
sex == "M"), lwd = 1.5)
lines(data_No_Interact_Model ~ BP, data = subset(data,
sex == "F"), lwd = 1.5)
# Test the improvement of the full model
anova(moleRatNoInteractModel, moleRatFullModel)
# Test the improvement of the full model
anova(data_No_Interact_Model, data_full_model)
## using 'Type III' sums of squares
dataNoInteractModelTypeIII <- lm(BP ~ Treatment + Sex, data = data,
contrasts = list(Sex = contr.sum))
library(car)
Anova(dataNoInteractModelTypeIII, type = "III")
dataNoInteractModel <- lm(BP ~ Treatment + Sex, data = data)
anova(dataNoInteractModel)
# Residual plot from the linear model
plot( residuals(dataNoInteractModelTypeIII) ~ fitted(data_No_Interact_Model) )
abline(0,0)
# normal Quantile plot of residuals
qqnorm(residuals(dataNoInteractModel), pch = 16, col = "firebrick",
las = 1, ylab = "Residuals", xlab = "Normal quantile", main = "")
# initial import of data to R
bp <- read_csv("data.csv")
# initial import of data to R
bp <- read_csv("data.csv")
view(bp)
# changing the treatment column so R sees it as a categorical variable
bp$Treatment <- as.factor(bp$Treatment)
# Visualizing the differences in BP in regards to sex regardless of treatment type
ggplot(bp, aes(x = Sex, y = BP)) +
geom_violin(trim = FALSE)
# Visualizing the differences in BP in regards to medication regardless of sex
ggplot(bp, aes(x = Treatment, y = BP)) +
geom_violin(trim = FALSE)
# Visualizing the differences in BP for each medication for both men and women
ggplot(bp, aes(x = Treatment, y = BP, fill = Sex)) +
geom_violin(trim = FALSE)
# Adding the data points
ggplot(bp, aes(x = Treatment, y = BP, fill = Sex)) +
geom_violin(trim = FALSE) +
geom_dotplot(binaxis = 'y', stackdir = 'center',
position = position_dodge(1))
# fit models to the data beginning with the model lacking an interaction term
# ni = 'no interaction'
np_ni_model <- lm(BP ~ Treatment + Sex, data = bp)
bp$predicted_ni <- predict(np_ni_model)
# Fit the full model which includes and interaction term
# fm = 'full model'
bp_fm <- lm(BP ~ Treatment * Sex, data = data)
# Fit the full model which includes and interaction term
# fm = 'full model'
bp_fm <- lm(BP ~ Treatment * Sex, data = bp)
data$predicted_fm <- predict(bp_fm)
# Visualize the model fits
lines(data_No_Interact_Model ~ BP, data = subset(data,
sex == "M"), lwd = 1.5)
# Visualize the fit of the full model
lines(predictedInteract ~ lnMass, data = subset(moleRatSorted,
caste == "worker"), lwd = 1.5, lty = 2)
lines(predictedInteract ~ lnMass, data = subset(moleRatSorted,
caste == "lazy"), lwd = 1.5, lty = 2)
bp_ni_model <- lm(BP ~ Treatment + Sex, data = bp)
# Test the improvement of the full model
anova(bp_ni_model, bp_fm)
## using 'Type III' sums of squares
bp_ni_III <- lm(BP ~ Treatment + Sex, data = bp,
contrasts = list(Sex = contr.sum))
Anova(bp_ni_III, type = "III")
# Loading the 'tidyverse' and 'car' packages
library(tidyverse, car)
bp_ni_I <- lm(BP ~ Treatment + Sex, data = bp)
anova(bp_ni_I)
# Residual plot from the linear model
plot( residuals(bp_ni_III) ~ fitted(bp_ni_I) )
abline(0,0)
# normal Quantile plot of residuals
qqnorm(residuals(bp_ni_I), pch = 16, col = "firebrick",
las = 1, ylab = "Residuals", xlab = "Normal quantile", main = "")
